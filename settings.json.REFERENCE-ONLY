{
  // ╔══════════════════════════════════════════════════════════════════════╗
  // ║  ⚠️  DO NOT COPY THIS FILE TO ~/.claude/settings.json DIRECTLY     ║
  // ║                                                                     ║
  // ║  The LLMGW installer writes your auth key to settings.json.         ║
  // ║  Copying this file OVERWRITES your auth and BREAKS Claude Code.     ║
  // ║                                                                     ║
  // ║  Instead: use setup.sh which MERGES hooks into your existing file.  ║
  // ║  Or: manually copy individual blocks from here into your file.      ║
  // ╚══════════════════════════════════════════════════════════════════════╝
  //
  // This is a REFERENCE file showing all available configuration options.
  // Your actual settings.json is managed by the LLMGW installer.

  // Model selection — use your organization's preferred model
  "model": "claude-sonnet-4-20250514",

  // Environment variables available to hooks and scripts
  "env": {
    // Your Anthropic auth token (if not using org SSO)
    // "ANTHROPIC_AUTH_TOKEN": "sk-ant-...",

    // Salesforce CLI default org alias
    "SF_TARGET_ORG": "my-default-org",

    // Custom variables for your hooks
    "CLAUDE_WIKI_DIR": "~/.claude/wiki",
    "CLAUDE_MEMORY_DIR": "~/.claude/memory"
  },

  // Permissions — tools Claude can use without asking each time
  "permissions": {
    "allow": [
      // Read-only operations (safe to auto-approve)
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(wc *)",
      "Bash(which *)",

      // Salesforce CLI read operations
      "Bash(sf org display*)",
      "Bash(sf data query*)",
      "Bash(sf project retrieve*)",

      // MCP tools you trust
      "mcp__slack__slack_read_channel",
      "mcp__slack__slack_search_public",
      "mcp__github__get_file_contents",
      "mcp__github__list_issues",

      // File operations in safe directories
      "Read",
      "Write(~/.claude/memory/*)",
      "Write(~/.claude/wiki/*)",
      "Edit(~/.claude/memory/*)",
      "Edit(~/.claude/wiki/*)"
    ],
    "deny": [
      // Never auto-approve destructive operations
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(sf org delete*)",
      "Bash(gcloud * delete*)"
    ]
  },

  // Hooks — scripts that fire at specific lifecycle events
  "hooks": {
    // Fires once at the start of every session
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 ~/.claude/hooks/scripts/session-init.py"
      }
    ],

    // Fires before Claude executes any tool
    "PreToolUse": [
      {
        // Block dangerous bash commands
        "type": "command",
        "command": "python3 ~/.claude/hooks/scripts/guardrail.py",
        "matcher": {
          "tool_name": "Bash"
        }
      },
      {
        // Check for hallucinated product names on file writes
        "type": "command",
        "command": "python3 ~/.claude/hooks/scripts/product-verification.py",
        "matcher": {
          "tool_name": ["Edit", "Write"]
        }
      }
    ],

    // Fires after Claude completes a tool execution
    "PostToolUse": [
      {
        // Scan written content for AI-sounding language
        "type": "command",
        "command": "python3 ~/.claude/hooks/scripts/output-quality-gate.py",
        "matcher": {
          "tool_name": "Write"
        }
      }
    ],

    // Fires when Claude's stop turn completes
    "Stop": []
  }
}
